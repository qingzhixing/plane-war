theme_override_font_sizes/normal_font_size = 18
bbcode_enabled = true
text = "[b]plane-war 更新日志（节选）[/b]
[color=#8af]v0.2.2[/color] - 2026-03-17
- 引入 2 条命离散生命值系统，生命归零当次立刻结算本局。
- 每波结束若生命未满 2 条，会自动恢复 1 命。
- HUD 补全生命展示，并加强死亡结算提示。

[color=#8af]v0.2.1[/color] - 2026-03-16
- 新增发版检查清单章节，对齐工程与导出版本号。

完整更新记录请见下方 GitHub 按钮。"
fit_content = true
scroll_active = false

